<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 主题样式 - 使用 Material3 -->
    <style name="Theme.NovelReader" parent="android:Theme.Material.Light.NoActionBar">
        <!-- 主色调 -->
        <item name="android:colorPrimary">@color/primary</item>
        <item name="android:colorPrimaryDark">@color/primary_variant</item>
        <item name="android:colorAccent">@color/secondary</item>

        <!-- 状态栏颜色 -->
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>

        <!-- 背景色 -->
        <item name="android:colorBackground">@color/background</item>

        <!-- 文字颜色 -->
        <item name="android:textColorPrimary">@color/on_background</item>
        <item name="android:textColorSecondary">@color/on_surface</item>
    </style>
</resources>
